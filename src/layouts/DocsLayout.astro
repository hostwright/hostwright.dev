---
import type { MarkdownHeading } from "astro";
import BaseLayout from "./BaseLayout.astro";
import DocsSidebar from "../components/DocsSidebar.astro";
import TableOfContents from "../components/TableOfContents.astro";
import Pagination from "../components/Pagination.astro";
import { siblings } from "../data/nav.ts";
import { site } from "../data/site.ts";

interface Props {
  title: string;
  description: string;
  slug: string;
  headings: MarkdownHeading[];
}
const { title, description, slug, headings } = Astro.props;
const { prev, next } = siblings(slug);
const pageTitle = `${title} · ${site.name} Docs`;
---

<BaseLayout title={pageTitle} description={description}>
  <div class="docs container">
    {/* Persistent sidebar on wide screens. */}
    <aside class="docs-rail">
      <DocsSidebar currentSlug={slug} />
    </aside>

    {/* Collapsible menu on narrow screens. Same data, works without JS. */}
    <details class="docs-rail-mobile">
      <summary class="docs-rail-toggle">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
        Documentation menu
      </summary>
      <div class="docs-rail-mobile-panel">
        <DocsSidebar currentSlug={slug} />
      </div>
    </details>

    <article class="docs-content prose">
      <header class="docs-header">
        <h1>{title}</h1>
        <p class="lead">{description}</p>
      </header>
      <slot />
      <Pagination prev={prev} next={next} />
    </article>

    <div class="docs-toc">
      <TableOfContents headings={headings} />
    </div>
  </div>
</BaseLayout>

<style>
  .docs {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    padding-block: var(--space-6) var(--space-8);
    align-items: start;
  }

  /* Desktop rail: hidden until there is room for a real column. */
  .docs-rail {
    display: none;
  }

  /* Mobile menu. */
  .docs-rail-mobile {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
  }
  .docs-rail-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    cursor: pointer;
    list-style: none;
  }
  .docs-rail-toggle::-webkit-details-marker {
    display: none;
  }
  .docs-rail-mobile-panel {
    padding: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .docs-toc {
    display: none;
  }

  /* Tablet+: real sidebar column, mobile menu hidden. */
  @media (min-width: 64rem) {
    .docs {
      grid-template-columns: var(--sidebar-width) minmax(0, 1fr);
      gap: var(--space-8);
    }
    .docs-rail-mobile {
      display: none;
    }
    .docs-rail {
      display: block;
      position: sticky;
      top: calc(var(--header-height) + var(--space-5));
      max-height: calc(100vh - var(--header-height) - var(--space-6));
      overflow-y: auto;
    }
  }

  /* Wide: add the on-page TOC column. */
  @media (min-width: 80rem) {
    .docs {
      grid-template-columns: var(--sidebar-width) minmax(0, 1fr) 13rem;
    }
    .docs-toc {
      display: block;
    }
  }

  .docs-content {
    min-width: 0;
    max-width: var(--width-prose);
  }
  .docs-header {
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--color-border);
  }
  .docs-header h1 {
    font-size: var(--text-3xl);
  }
  .docs-header .lead {
    margin-top: var(--space-3);
  }
</style>

<style is:global>
  /* MDX body. Scoped to .prose so it does not leak into chrome. */
  .prose :where(h2) {
    font-size: var(--text-2xl);
    margin-top: var(--space-7);
    margin-bottom: var(--space-3);
    padding-top: var(--space-2);
  }
  .prose :where(h3) {
    font-size: var(--text-xl);
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }
  .prose :where(p, ul, ol, blockquote, .astro-code, table) {
    margin-bottom: var(--space-4);
  }
  .prose :where(p, li) {
    color: var(--color-text);
    line-height: var(--leading-normal);
  }
  .prose :where(ul, ol) {
    padding-left: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .prose :where(li)::marker {
    color: var(--color-text-faint);
  }
  .prose :where(blockquote) {
    border-left: 3px solid var(--color-border-strong);
    padding-left: var(--space-4);
    color: var(--color-text-muted);
  }
  .prose :where(hr) {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin-block: var(--space-6);
  }
  .prose :where(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    display: block;
    overflow-x: auto;
  }
  .prose :where(th, td) {
    border: 1px solid var(--color-border);
    padding: var(--space-2) var(--space-3);
    text-align: left;
    vertical-align: top;
  }
  .prose :where(th) {
    background: var(--color-surface);
    font-weight: var(--weight-semibold);
  }
  .prose :where(h2, h3) > a {
    color: inherit;
    text-decoration: none;
  }
</style>
