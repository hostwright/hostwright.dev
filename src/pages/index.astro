---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import TerminalBuildFilm from "../components/TerminalBuildFilm.astro";
import SectionHeading from "../components/SectionHeading.astro";
import NonGoalsList from "../components/NonGoalsList.astro";
import CliPreview from "../components/CliPreview.astro";
import CliTerminal from "../components/CliTerminal.astro";
import ManifestPreview from "../components/ManifestPreview.astro";
import Figure from "../components/Figure.astro";
import RoadmapGrid from "../components/RoadmapGrid.astro";

import { site } from "../data/site.ts";
import { problem, whatItIs, safety, architecture } from "../data/homepage.ts";

const title = `${site.name} · ${site.tagline}`;

const community = [
  { label: "GitHub", detail: "Source, issues, and design records.", href: site.links.github, external: true },
  { label: "X", detail: "Project updates and release notes.", href: site.links.x, external: true },
  { label: "Reddit", detail: "Discussion and questions.", href: site.links.reddit, external: true },
  { label: "Documentation", detail: "Concepts, tasks, reference, and operations.", href: site.links.docs, external: true },
];
---

<BaseLayout title={title}>
  <Hero />
  <TerminalBuildFilm />

  <!-- Plan demo -->
  <section class="section section-demo">
    <div class="container demo-grid">
      <div class="demo-copy">
        <h2 class="demo-title">Plan before mutation.</h2>
        <p class="demo-lead">
          Every run computes a reviewable plan from the manifest.
          <code>plan</code> is non-mutating; mutation requires exact
          confirmation and crosses the same identity, provider, and ledger
          boundaries.
        </p>
      </div>
      <CliTerminal />
    </div>
  </section>

  <!-- Problem -->
  <section class="section">
    <div class="container reveal">
      <SectionHeading title={problem.heading} />
      <div class="prose-block">
        {problem.body.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </section>

  <!-- What Hostwright is -->
  <section class="section">
    <div class="container reveal">
      <SectionHeading title={whatItIs.heading} lead={whatItIs.intro} />
      <ul class="feature-grid">
        {
          whatItIs.capabilities.map((c) => (
            <li class="feature">
              <h3>{c.title}</h3>
              <p>{c.detail}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- CLI preview -->
  <section class="section">
    <div class="container reveal">
      <SectionHeading title="The CLI" />
      <CliPreview />
    </div>
  </section>

  <!-- Architecture -->
  <section class="section">
    <div class="container reveal">
      <SectionHeading title={architecture.heading} lead={architecture.intro} />
      <Figure
        src="/diagrams/01-system-layer-stack.svg"
        alt="Layered architecture: the hostwright CLI and planned daemon sit above the RuntimeAdapter boundary, which drives Apple's container runtime and Linux VMs."
        caption="Apple container is the execution substrate. Hostwright owns versioned intent, planning, policy, identity, recovery state, and narrow confirmed runtime paths behind Runtime Provider API v2."
        dense
      />
    </div>
  </section>

  <!-- Manifest -->
  <section class="section">
    <div class="container reveal">
      <SectionHeading title="Declare a stack in one file" />
      <ManifestPreview />
    </div>
  </section>

  <!-- Safety -->
  <section class="section">
    <div class="container reveal">
      <SectionHeading title={safety.heading} lead={safety.intro} />
      <ul class="safety-grid">
        {
          safety.principles.map((s) => (
            <li class="safety-item">
              <h3>{s.title}</h3>
              <p>{s.detail}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Roadmap -->
  <section class="section" id="roadmap">
    <div class="container reveal">
      <SectionHeading
        title="Roadmap"
        lead="Fifteen phases. Planned work is not current support."
      />
      <RoadmapGrid />
    </div>
  </section>

  <!-- Boundaries and fallbacks -->
  <section class="section">
    <div class="container reveal">
      <SectionHeading
        title="Boundaries and fallbacks"
        lead="Only unsafe mechanisms are excluded. External constraints have implementable fallbacks."
      />
      <NonGoalsList />
    </div>
  </section>

  <!-- Community -->
  <section class="section">
    <div class="container reveal">
      <SectionHeading title="Community" />
      <ul class="community-grid">
        {
          community.map((c) => (
            <li>
              <a class="community-card" href={c.href} {...(c.external ? { rel: "noopener" } : {})}>
                <span class="community-label">
                  {c.label}
                  {c.external ? " ↗" : ""}
                </span>
                <span class="community-detail">{c.detail}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .section-demo {
    background: var(--color-surface);
  }
  .demo-grid {
    display: grid;
    gap: var(--space-6);
    align-items: center;
  }
  .demo-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .demo-title {
    font-size: var(--text-2xl);
    max-width: 16ch;
  }
  .demo-lead {
    max-width: 46ch;
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    line-height: var(--leading-snug);
  }
  .demo-lead code {
    font-size: 0.85em;
  }
  @media (min-width: 56rem) {
    .demo-grid {
      grid-template-columns: 0.85fr 1.15fr;
      gap: var(--space-7);
    }
  }

  .prose-block {
    max-width: var(--width-prose);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
  }

  .feature-grid {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  .feature {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-5);
    background: var(--color-bg);
  }
  .feature h3 {
    font-size: var(--text-base);
  }
  .feature p {
    margin-top: var(--space-2);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .safety-grid {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-1) var(--space-7);
    grid-template-columns: 1fr;
  }
  .safety-item {
    padding: var(--space-4) 0 var(--space-4) var(--space-4);
    border-left: 2px solid var(--color-accent);
    border-bottom: 1px solid var(--color-border);
  }
  .safety-item h3 {
    font-size: var(--text-base);
  }
  .safety-item p {
    margin-top: var(--space-1);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .community-grid {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-3);
    grid-template-columns: 1fr;
  }
  .community-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    background: var(--color-bg);
    transition:
      border-color var(--duration) var(--ease),
      transform var(--duration) var(--ease);
  }
  .community-card:hover {
    border-color: var(--color-text-faint);
  }
  .community-label {
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }
  .community-detail {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  @media (min-width: 40rem) {
    .feature-grid,
    .safety-grid,
    .community-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 64rem) {
    .feature-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .community-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
