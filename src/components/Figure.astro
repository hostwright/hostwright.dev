---
// A diagram with caption. SVGs live in public/diagrams and carry their own
// off-white background, so they sit flush on the page with a hairline frame.
// `dense` marks detailed diagrams that need a minimum width to stay legible on
// phones — those scroll horizontally on small screens instead of shrinking.
interface Props {
  src: string;
  alt: string;
  caption?: string;
  max?: string;
  dense?: boolean;
}
const { src, alt, caption, max, dense } = Astro.props;
---

<figure class="figure" style={max ? `--figure-max: ${max}` : undefined}>
  <div class:list={["figure-media", { dense }]}>
    <img src={src} alt={alt} loading="lazy" decoding="async" />
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .figure {
    margin-block: var(--space-6);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }
  .figure-media {
    width: 100%;
    max-width: var(--figure-max, 100%);
  }
  .figure img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg);
  }
  .figure figcaption {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
    max-width: var(--width-prose);
  }

  /* Detailed diagrams stay legible on phones: give the image a minimum width
     and let its frame scroll horizontally. Gated to small screens so wide
     desktop layouts never scroll. */
  @media (max-width: 47.99rem) {
    .figure-media.dense {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .figure-media.dense img {
      min-width: 30rem;
    }
  }
</style>
