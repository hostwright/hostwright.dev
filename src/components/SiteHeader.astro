---
import HostwrightLogo from "./HostwrightLogo.astro";
import { site } from "../data/site.ts";

const navLinks = [
  { label: "Docs", href: "https://docs.hostwright.dev/" },
  { label: "Concepts", href: "https://docs.hostwright.dev/concepts/desired-state/" },
  { label: "Reference", href: "https://docs.hostwright.dev/reference/cli/" },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="header-logo" aria-label="Hostwright home">
      <HostwrightLogo size={26} />
    </a>

    <!-- Desktop nav: a plain <nav> so it never depends on the <details>
         open state (a closed <details> hides its content in Safari/Chromium
         regardless of author `display`). -->
    <nav class="nav-desktop" aria-label="Primary">
      {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
      <a class="nav-github" href={site.links.github} rel="noopener">GitHub ↗</a>
    </nav>

    <!-- Mobile nav: disclosure menu, hidden on desktop. -->
    <details class="nav-mobile">
      <summary class="nav-toggle" aria-label="Toggle navigation">
        <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </summary>
      <nav class="nav-menu" aria-label="Menu">
        {navLinks.map((l) => <a href={l.href}>{l.label}</a>)}
        <a class="nav-github" href={site.links.github} rel="noopener">GitHub ↗</a>
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--color-border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
  }
  .header-logo {
    display: inline-block;
    text-decoration: none;
    color: var(--color-text);
    border-radius: var(--radius-sm);
    transform: scale(var(--logo-scale, 1));
    transform-origin: left center;
  }

  /* Desktop nav: hidden on small screens, inline row on wide screens. */
  .nav-desktop {
    display: none;
  }
  .nav-desktop a {
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
  }
  .nav-desktop a:hover {
    background: var(--color-surface);
  }

  .nav-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    cursor: pointer;
    color: var(--color-text);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    list-style: none;
  }
  .nav-toggle::-webkit-details-marker {
    display: none;
  }

  .nav-menu {
    display: none;
    flex-direction: column;
    gap: var(--space-1);
    position: absolute;
    right: var(--space-5);
    top: calc(var(--header-height) - 0.4rem);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-3);
    min-width: 12rem;
    box-shadow: 0 12px 32px -16px rgba(32, 35, 39, 0.3);
  }
  .nav-menu a {
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
  }
  .nav-menu a:hover {
    background: var(--color-surface);
    color: var(--color-text);
  }
  .nav-github {
    color: var(--color-accent) !important;
  }

  /* Mobile: reveal the dropdown only when the disclosure is open. */
  .nav-mobile[open] .nav-menu {
    display: flex;
  }

  @media (min-width: 48rem) {
    .nav-desktop {
      display: flex;
      align-items: center;
      gap: var(--space-2);
    }
    .nav-mobile {
      display: none;
    }
  }
</style>

<script>
  // The logo arrives large — an entrance, not a permanent fixture — then
  // settles to its normal navbar size as the page is scrolled, continuously
  // tied to scroll position. transform-only, so it never shifts layout.
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const logo = document.querySelector<HTMLElement>(".header-logo");
  const navDesktop = document.querySelector<HTMLElement>(".nav-desktop");
  const navMobile = document.querySelector<HTMLElement>(".nav-mobile");

  if (logo && !reduce) {
    const RANGE = 180; // px of scroll over which it settles to 1
    let maxScale = 1;
    let ticking = false;

    function computeMaxScale() {
      // Cap the entrance scale to whatever room actually exists before
      // whichever nav control is visible, so the logo never collides.
      const visible = [navDesktop, navMobile].find((el) => el && el.offsetParent !== null);
      const logoBox = logo!.getBoundingClientRect();
      const controlsLeft = visible?.getBoundingClientRect().left ?? Infinity;
      const available = controlsLeft - logoBox.left - 24;
      maxScale = Math.min(1.7, Math.max(1, available / logoBox.width));
    }

    function update() {
      const t = Math.min(1, window.scrollY / RANGE);
      const scale = maxScale - (maxScale - 1) * t;
      logo!.style.setProperty("--logo-scale", scale.toFixed(3));
      ticking = false;
    }
    computeMaxScale();
    update();
    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true }
    );
    window.addEventListener(
      "resize",
      () => {
        computeMaxScale();
        update();
      },
      { passive: true }
    );
  }
</script>
