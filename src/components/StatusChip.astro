---
import type { Status } from "../data/roadmap.ts";
import { statusLabel } from "../data/roadmap.ts";

interface Props {
  status: Status;
}
const { status } = Astro.props;
---

<span class={`chip chip-${status}`}>
  <span class="dot" aria-hidden="true"></span>
  {statusLabel[status]}
</span>

<style>
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    border: 1px solid transparent;
    white-space: nowrap;
  }
  .dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: currentColor;
  }
  .chip-planned {
    color: var(--status-planned);
    background: var(--status-planned-bg);
    border-color: color-mix(in srgb, var(--status-planned) 22%, transparent);
  }
  .chip-in-progress {
    color: var(--status-progress);
    background: var(--status-progress-bg);
    border-color: color-mix(in srgb, var(--status-progress) 22%, transparent);
  }
  .chip-implemented {
    color: var(--status-implemented);
    background: var(--status-implemented-bg);
    border-color: color-mix(in srgb, var(--status-implemented) 22%, transparent);
  }
  .chip-blocked {
    color: var(--status-blocked);
    background: var(--status-blocked-bg);
    border-color: color-mix(in srgb, var(--status-blocked) 22%, transparent);
  }
</style>
