---
import { Code } from "astro:components";
import { manifestExample } from "../data/homepage.ts";
---

<figure class="manifest">
  <div class="term">
    <div class="term-bar">
      <span class="term-label">hostwright.yaml</span>
    </div>
    <Code code={manifestExample} lang="yaml" theme="github-light" />
  </div>
  <figcaption>
    A stack is declared in a single readable file. Each field shown here is
    documented in the <a href="/docs/reference/hostwright-yaml/">manifest reference</a>.
  </figcaption>
</figure>

<style>
  .manifest {
    margin: 0;
    max-width: 40rem;
  }
  .term {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    background: #fcfbf8;
  }
  .term-bar {
    padding: var(--space-2) var(--space-4);
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }
  .term-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
  .manifest :global(pre.astro-code) {
    border: 0 !important;
    border-radius: 0 !important;
    margin: 0;
  }
  figcaption {
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
