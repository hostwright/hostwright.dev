---
import { hero } from "../data/homepage.ts";
import HeroMotif from "./HeroMotif.astro";
import HeroScene from "./hero/HeroScene.tsx";
---

<section class="hero">
  <div class="hero-stage" aria-hidden="true">
    <HeroScene client:only="react" />
  </div>
  <div class="hero-scrim" aria-hidden="true"></div>
  <div class="container hero-grid">
    <div class="hero-inner">
      <a class="hero-status" href="#roadmap">
        <span class="dot" aria-hidden="true"></span>
        {hero.status}
      </a>
      <h1 class="hero-title">{hero.title}</h1>
      <p class="hero-subtitle">{hero.subtitle}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href={hero.ctaPrimary.href}>{hero.ctaPrimary.label}</a>
        <a class="btn btn-secondary" href={hero.ctaSecondary.href} rel="noopener">
          {hero.ctaSecondary.label} ↗
        </a>
      </div>
    </div>
    <HeroMotif />
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(var(--space-8), 4vw + var(--space-6), var(--space-10))
      var(--space-9);
  }
  /* 3D stage: hidden by default; only revealed on wide + motion-allowed. */
  .hero-stage {
    display: none;
  }
  /* Legibility scrim: paper fading out over the left, so the headline stays
     crisp above the fleet. Functional (paper-on-paper), not decorative. */
  .hero-scrim {
    display: none;
  }
  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    gap: var(--space-8);
    align-items: center;
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-5);
  }
  /* 2D mark (fallback): shows on all sizes until the 3D scene replaces it. */
  .hero-grid :global(.mark) {
    order: -1;
    max-width: 15rem;
    justify-self: start;
    margin-bottom: var(--space-2);
  }
  @media (min-width: 64rem) {
    .hero-grid {
      grid-template-columns: 1.25fr 1fr;
    }
    .hero-grid :global(.mark) {
      order: 0;
      max-width: 26rem;
      justify-self: end;
      margin-bottom: 0;
    }
  }
  /* The cinematic upgrade: real-time fleet replaces the 2D mark. */
  @media (min-width: 64rem) and (prefers-reduced-motion: no-preference) {
    .hero {
      min-height: min(86vh, 58rem);
      display: flex;
      align-items: center;
    }
    .hero-stage {
      display: block;
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }
    .hero-scrim {
      display: block;
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background: linear-gradient(
        90deg,
        var(--color-bg) 0%,
        var(--color-bg) 26%,
        color-mix(in srgb, var(--color-bg) 40%, transparent) 44%,
        transparent 60%
      );
    }
    .hero-grid {
      grid-template-columns: 1fr;
      width: 100%;
    }
    .hero-grid :global(.mark) {
      display: none;
    }
    .hero-inner {
      max-width: 34rem;
    }
  }
  .hero-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--color-border-strong);
    border-radius: 999px;
    background: var(--color-surface);
  }
  .hero-status:hover {
    color: var(--color-text);
    border-color: var(--color-text-faint);
  }
  .hero-status .dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--color-accent);
  }
  .hero-title {
    max-width: 15ch;
    font-size: var(--text-4xl);
    line-height: 1.02;
    letter-spacing: var(--track-display);
  }
  .hero-subtitle {
    max-width: 52ch;
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-3);
  }
</style>
