---
import { hero } from "../data/homepage.ts";
import HeroMotif from "./HeroMotif.astro";
import HeroScene from "./hero/HeroScene.tsx";

// Feature captions, each floating above its own container once the fleet
// settles onto the bridge.
const stations = [
  { label: "Declare", note: "one manifest" },
  { label: "Plan", note: "before mutation" },
  { label: "Reconcile", note: "desired vs actual" },
  { label: "Detect drift", note: "and correct" },
  { label: "Doctor", note: "safe checks" },
  { label: "Clean up", note: "dry-run first" },
];
---

<section class="hero" id="hero-film" data-phase="1">
  <div class="hero-sticky">
    <div class="hero-stage" aria-hidden="true">
      <HeroScene client:only="react" stations={stations} />
    </div>
    <div class="hero-scrim" aria-hidden="true"></div>

    <div class="container hero-overlays">
      <!-- Phase 1 — drift. The real headline (SEO / no-JS lives here). -->
      <div class="ov ov-1">
        <div class="hero-inner">
          <h1 class="hero-title">{hero.title}</h1>
          <p class="hero-subtitle">{hero.subtitle}</p>
          <div class="hero-actions">
            <a class="btn btn-primary" href={hero.ctaPrimary.href}>{hero.ctaPrimary.label}</a>
            <a class="btn btn-secondary" href={hero.ctaSecondary.href} rel="noopener">
              {hero.ctaSecondary.label} ↗
            </a>
          </div>
          <HeroMotif />
        </div>
      </div>

      <!-- Phase 2 — assemble on the control plane. -->
      <div class="ov ov-2" aria-hidden="true">
        <p class="ov-lead">
          Every container declared, reconciled, and kept in its declared
          state. One Mac, one control plane.
        </p>
      </div>

      <!-- Phase 3 — disperse onto the H. Each feature's name floats above
           its own container in 3D; this closes the loop below the shelf. -->
      <div class="ov ov-3" aria-hidden="true">
        <p class="ov-lead">
          Six steps, one loop. Every apply runs in the same order.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  /* ---- Fallback layout (mobile / reduced-motion / no-WebGL): a normal hero. */
  .hero {
    position: relative;
    padding-block: clamp(var(--space-8), 4vw + var(--space-6), var(--space-10))
      var(--space-9);
  }
  .hero-sticky {
    display: block;
  }
  .hero-stage,
  .hero-scrim,
  .ov-2,
  .ov-3 {
    display: none;
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-5);
  }
  .hero-grid :global(.mark),
  .hero-inner :global(.mark) {
    max-width: 15rem;
    margin-top: var(--space-2);
  }
  @media (min-width: 64rem) {
    .hero-inner :global(.mark) {
      max-width: 22rem;
    }
  }

  /* ---- Film layout: the pinned scroll cinema. ---- */
  @media (min-width: 64rem) and (prefers-reduced-motion: no-preference) {
    .hero {
      height: 220vh;
      padding: 0;
    }
    .hero-sticky {
      position: sticky;
      top: 0;
      height: 100vh;
      overflow: hidden;
    }
    .hero-stage {
      display: block;
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }
    .hero-scrim {
      display: block;
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: clamp(0, calc(1 - var(--p, 0) * 3.2), 1);
      background: linear-gradient(
        90deg,
        var(--color-bg) 0%,
        var(--color-bg) 24%,
        color-mix(in srgb, var(--color-bg) 40%, transparent) 42%,
        transparent 58%
      );
    }
    .hero-overlays {
      position: relative;
      z-index: 1;
      height: 100vh;
    }
    .hero-inner :global(.mark) {
      display: none;
    }

    .ov {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.5s var(--ease);
    }
    .ov a.btn {
      pointer-events: auto;
    }
    .ov-2 {
      display: flex;
      align-items: center;
      text-align: center;
    }
    .ov-3 {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      text-align: center;
      padding-bottom: clamp(var(--space-8), 6vw, var(--space-10));
    }
    .ov-1 {
      align-items: flex-start;
    }
    [data-phase="1"] .ov-1 {
      opacity: 1;
    }
    [data-phase="2"] .ov-2 {
      opacity: 1;
    }
    [data-phase="3"] .ov-3 {
      opacity: 1;
    }

    .ov-lead {
      max-width: 26ch;
      font-family: var(--font-display, var(--font-sans));
      font-size: var(--text-2xl);
      line-height: 1.2;
      letter-spacing: var(--track-display);
      color: var(--color-text);
      margin-inline: auto;
      padding: var(--space-5) var(--space-6);
      border-radius: var(--radius-lg);
      background: var(--color-bg);
      box-shadow: 0 12px 32px -16px rgba(32, 35, 39, 0.35);
    }
  }

  /* ---- Shared copy styles. ---- */
  .hero-title {
    max-width: 15ch;
    font-size: var(--text-4xl);
    line-height: 1.02;
    letter-spacing: var(--track-display);
  }
  .hero-subtitle {
    max-width: 52ch;
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-3);
  }
</style>

<script>
  // Single source of scroll progress → phase class + --p, from the 3D island.
  // Per-feature captions float above their own container in 3D once
  // dispersed, so this script only owns the headline / control-plane
  // overlays.
  const film = document.getElementById("hero-film");
  if (film) {
    let phase = 1;
    window.addEventListener("hero-progress", (e) => {
      const p = (e as CustomEvent<number>).detail;
      film.style.setProperty("--p", p.toFixed(3));
      const ph = p < 0.34 ? 1 : p < 0.6 ? 2 : 3;
      if (ph !== phase) {
        phase = ph;
        film.dataset.phase = String(ph);
      }
    });
  }
</script>
