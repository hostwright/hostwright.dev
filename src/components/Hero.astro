---
import { hero } from "../data/homepage.ts";
import HeroMotif from "./HeroMotif.astro";
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-inner">
      <a class="hero-status" href="#roadmap">
        <span class="dot" aria-hidden="true"></span>
        {hero.status}
      </a>
      <h1 class="hero-title">{hero.title}</h1>
      <p class="hero-subtitle">{hero.subtitle}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href={hero.ctaPrimary.href}>{hero.ctaPrimary.label}</a>
        <a class="btn btn-secondary" href={hero.ctaSecondary.href} rel="noopener">
          {hero.ctaSecondary.label} ↗
        </a>
      </div>
    </div>
    <HeroMotif />
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(var(--space-8), 4vw + var(--space-6), var(--space-10))
      var(--space-9);
  }
  .hero-grid {
    display: grid;
    gap: var(--space-8);
    align-items: center;
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-5);
  }
  /* Mark shows on all sizes; it stacks below the copy on narrow screens. */
  .hero-grid :global(.mark) {
    order: -1;
    max-width: 15rem;
    justify-self: start;
    margin-bottom: var(--space-2);
  }
  @media (min-width: 64rem) {
    .hero-grid {
      grid-template-columns: 1.25fr 1fr;
    }
    .hero-grid :global(.mark) {
      order: 0;
      max-width: 26rem;
      justify-self: end;
      margin-bottom: 0;
    }
  }
  .hero-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--color-border-strong);
    border-radius: 999px;
    background: var(--color-surface);
  }
  .hero-status:hover {
    color: var(--color-text);
    border-color: var(--color-text-faint);
  }
  .hero-status .dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--color-accent);
  }
  .hero-title {
    max-width: 15ch;
    font-size: var(--text-4xl);
    line-height: 1.02;
    letter-spacing: var(--track-display);
  }
  .hero-subtitle {
    max-width: 52ch;
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-3);
  }
</style>
