---
import { hero } from "../data/homepage.ts";
import HeroMotif from "./HeroMotif.astro";
import HeroScene from "./hero/HeroScene.tsx";

// Feature stations for the disperse phase — short, honest labels.
const stations = [
  { label: "Declare", note: "one manifest" },
  { label: "Plan", note: "before mutation" },
  { label: "Reconcile", note: "desired vs actual" },
  { label: "Detect drift", note: "and correct" },
  { label: "Doctor", note: "safe checks" },
  { label: "Clean up", note: "dry-run first" },
];
---

<section class="hero" id="hero-film" data-phase="1">
  <div class="hero-sticky">
    <div class="hero-stage" aria-hidden="true">
      <HeroScene client:only="react" />
    </div>
    <div class="hero-scrim" aria-hidden="true"></div>

    <div class="container hero-overlays">
      <!-- Phase 1 — drift. The real headline (SEO / no-JS lives here). -->
      <div class="ov ov-1">
        <div class="hero-inner">
          <a class="hero-status" href="#roadmap">
            <span class="dot" aria-hidden="true"></span>
            {hero.status}
          </a>
          <h1 class="hero-title">{hero.title}</h1>
          <p class="hero-subtitle">{hero.subtitle}</p>
          <div class="hero-actions">
            <a class="btn btn-primary" href={hero.ctaPrimary.href}>{hero.ctaPrimary.label}</a>
            <a class="btn btn-secondary" href={hero.ctaSecondary.href} rel="noopener">
              {hero.ctaSecondary.label} ↗
            </a>
          </div>
          <HeroMotif />
        </div>
      </div>

      <!-- Phase 2 — assemble on the control plane. -->
      <div class="ov ov-2" aria-hidden="true">
        <p class="ov-eyebrow">The control plane</p>
        <p class="ov-lead">
          Every container — declared, reconciled, and kept in the state you
          asked for. One Mac, one plane, in your control.
        </p>
      </div>

      <!-- Phase 3 — the crossing. -->
      <div class="ov ov-3" aria-hidden="true">
        <p class="ov-eyebrow">Delivered as one</p>
        <p class="ov-lead">
          Your whole stack, gathered and carried across on Hostwright —
          light, quick, and exactly as declared.
        </p>
      </div>

      <!-- Phase 4 — disperse into features. -->
      <div class="ov ov-4" aria-hidden="true">
        <p class="ov-eyebrow">One loop, six moves</p>
        <ul class="stations">
          {
            stations.map((s) => (
              <li>
                <span class="st-label">{s.label}</span>
                <span class="st-note">{s.note}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  /* ---- Fallback layout (mobile / reduced-motion / no-WebGL): a normal hero. */
  .hero {
    position: relative;
    padding-block: clamp(var(--space-8), 4vw + var(--space-6), var(--space-10))
      var(--space-9);
  }
  .hero-sticky {
    display: block;
  }
  .hero-stage,
  .hero-scrim,
  .ov-2,
  .ov-3,
  .ov-4 {
    display: none;
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-5);
  }
  .hero-grid :global(.mark),
  .hero-inner :global(.mark) {
    max-width: 15rem;
    margin-top: var(--space-2);
  }
  @media (min-width: 64rem) {
    .hero-inner :global(.mark) {
      max-width: 22rem;
    }
  }

  /* ---- Film layout: the pinned scroll cinema. ---- */
  @media (min-width: 64rem) and (prefers-reduced-motion: no-preference) {
    .hero {
      height: 460vh;
      padding: 0;
    }
    .hero-sticky {
      position: sticky;
      top: 0;
      height: 100vh;
      overflow: hidden;
    }
    .hero-stage {
      display: block;
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }
    .hero-scrim {
      display: block;
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: clamp(0, calc(1 - var(--p, 0) * 3.2), 1);
      background: linear-gradient(
        90deg,
        var(--color-bg) 0%,
        var(--color-bg) 24%,
        color-mix(in srgb, var(--color-bg) 40%, transparent) 42%,
        transparent 58%
      );
    }
    .hero-overlays {
      position: relative;
      z-index: 1;
      height: 100vh;
    }
    .hero-inner :global(.mark) {
      display: none;
    }

    .ov {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.5s var(--ease);
    }
    .ov a.btn {
      pointer-events: auto;
    }
    .ov-2,
    .ov-3,
    .ov-4 {
      display: flex;
      align-items: center;
      text-align: center;
    }
    .ov-3,
    .ov-4 {
      justify-content: flex-end;
      padding-bottom: 9vh;
    }
    /* crossing caption stays compact so the craft + cube own the frame */
    .ov-3 .ov-lead {
      max-width: 34ch;
      font-size: var(--text-xl);
    }
    .ov-1 {
      align-items: flex-start;
    }
    [data-phase="1"] .ov-1 {
      opacity: 1;
    }
    [data-phase="2"] .ov-2 {
      opacity: 1;
    }
    [data-phase="3"] .ov-3 {
      opacity: 1;
    }
    [data-phase="4"] .ov-4 {
      opacity: 1;
    }

    .ov-lead {
      max-width: 26ch;
      font-family: var(--font-display, var(--font-sans));
      font-size: var(--text-2xl);
      line-height: 1.2;
      letter-spacing: var(--track-display);
      color: var(--color-text);
      margin-inline: auto;
      padding: var(--space-5) var(--space-6);
      border-radius: var(--radius-lg);
      background: color-mix(in srgb, var(--color-bg) 74%, transparent);
      backdrop-filter: blur(7px);
    }
    .ov-eyebrow {
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-text-faint);
      margin-bottom: var(--space-4);
    }
    .stations {
      list-style: none;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: var(--space-4);
      max-width: 62rem;
      width: 100%;
      padding: var(--space-5);
      border-radius: var(--radius-lg);
      background: color-mix(in srgb, var(--color-bg) 72%, transparent);
      backdrop-filter: blur(7px);
    }
    .stations li {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      padding-top: var(--space-3);
      border-top: 1px solid var(--color-border-strong);
    }
    .st-label {
      font-weight: var(--weight-semibold);
      font-size: var(--text-base);
    }
    .st-note {
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      color: var(--color-text-muted);
    }
  }

  /* ---- Shared copy styles. ---- */
  .hero-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.02em;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--color-border-strong);
    border-radius: 999px;
    background: var(--color-surface);
  }
  .hero-status .dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--color-accent);
  }
  .hero-title {
    max-width: 15ch;
    font-size: var(--text-4xl);
    line-height: 1.02;
    letter-spacing: var(--track-display);
  }
  .hero-subtitle {
    max-width: 52ch;
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-3);
  }
</style>

<script>
  // Single source of scroll progress → phase class + --p, from the 3D island.
  const film = document.getElementById("hero-film");
  if (film) {
    let phase = 1;
    window.addEventListener("hero-progress", (e) => {
      const p = (e as CustomEvent<number>).detail;
      film.style.setProperty("--p", p.toFixed(3));
      const ph = p < 0.28 ? 1 : p < 0.44 ? 2 : p < 0.72 ? 3 : 4;
      if (ph !== phase) {
        phase = ph;
        film.dataset.phase = String(ph);
      }
    });
  }
</script>
