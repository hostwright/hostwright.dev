---
type Kind = "control" | "core" | "boundary" | "substrate";

interface Layer {
  name: string;
  role: string;
  kind: Kind;
}

const layers: Layer[] = [
  { name: "hostwright CLI", role: "Command surface", kind: "control" },
  { name: "hostwrightd", role: "Local daemon, supervision loops", kind: "control" },
  {
    name: "Planner · Reconciler · State Store",
    role: "Desired state, plans, drift, health, events",
    kind: "core",
  },
  {
    name: "RuntimeAdapter",
    role: "The typed boundary — every runtime call crosses here",
    kind: "boundary",
  },
  {
    name: "Apple container CLI / Containerization",
    role: "Execution substrate",
    kind: "substrate",
  },
  { name: "Lightweight Linux VMs", role: "Where containers run", kind: "substrate" },
];
---

<figure class="arch">
  <ol class="arch-stack" aria-label="Hostwright architecture from top to bottom">
    {
      layers.map((layer) => (
        <li class={`layer layer-${layer.kind}`}>
          {layer.kind === "boundary" && <span class="tag">boundary</span>}
          <span class="layer-name">{layer.name}</span>
          <span class="layer-role">{layer.role}</span>
        </li>
      ))
    }
  </ol>
  <figcaption class="arch-cap">
    Runtime changes flow downward and always cross the <strong>RuntimeAdapter</strong>.
    Hostwright owns declared state, planning, reconciliation, health, drift, events,
    and cleanup policy. Apple container is the execution substrate — Hostwright does
    not own Apple's runtime internals.
  </figcaption>
</figure>

<style>
  .arch {
    margin: 0;
  }
  .arch-stack {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    max-width: 36rem;
  }
  .layer {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: var(--space-4) var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg);
  }
  /* Decorative downward connector between layers. */
  .layer:not(:last-child)::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: calc(-1 * var(--space-4));
    transform: translateX(-50%);
    width: 1px;
    height: var(--space-4);
    background: var(--color-border-strong);
  }
  .layer:not(:last-child) {
    margin-bottom: var(--space-4);
  }
  .layer-name {
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
  }
  .layer-role {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .layer-core {
    background: var(--color-surface);
  }
  .layer-boundary {
    border-color: var(--color-accent);
    border-width: 1.5px;
    background: var(--color-accent-soft);
  }
  .layer-substrate {
    background: var(--color-surface);
    border-style: dashed;
    color: var(--color-text-muted);
  }
  .layer-substrate .layer-name {
    color: var(--color-text);
  }
  .tag {
    position: absolute;
    top: -0.6rem;
    right: var(--space-4);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: var(--color-bg);
    padding: 0.05rem 0.4rem;
    border: 1px solid var(--color-accent);
    border-radius: 999px;
  }
  .arch-cap {
    margin-top: var(--space-5);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    max-width: var(--width-prose);
  }
</style>
